generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id               String            @id @default(cuid())
  clerkId          String            @unique
  name             String?
  email            String?           @unique
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  profileCompleted Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  accounts         Account[]
  careerProfile    CareerProfile?
  chatSessions     ChatSession[]
  classSchedule    ClassSchedule[]
  examPrep         ExamPrep[]
  roadmaps         SemesterRoadmap[]
  sessions         Session[]
  syllabusTopics   SyllabusTopic[]
  tasks            Task[]
}

model CareerProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  interests            String[]
  skills               String[]
  personalityTraits    String[]
  expectedSalary       String?
  workLifeBalance      String?
  aiTopCareersRaw      Json?
  selectedCareer       String?
  careerReadinessScore Float?   @default(0.0)
  createdAt            DateTime @default(now())
  fullAssessmentResult Json?
  updatedAt            DateTime @default(now()) @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SemesterRoadmap {
  id               String   @id @default(cuid())
  userId           String
  semesterNumber   Int
  status           String   @default("PENDING")
  subjects         Json
  skills           Json
  projects         Json
  weeklyBreakdown  Json
  aiSuggestions    Json?
  performanceScore Float?
  gpa              Float?
  assignmentRate   Float?
  conceptScore     Float?
  timeConsistency  Float?
  mockTestScore    Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  environmentSetup Json?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Task {
  id          String    @id @default(cuid())
  userId      String
  title       String
  type        String
  priority    String    @default("MEDIUM")
  status      String    @default("PENDING")
  dueDate     DateTime?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClassSchedule {
  id              String   @id @default(cuid())
  userId          String
  subjectName     String
  dayOfWeek       Int
  startTime       String
  endTime         String
  location        String?
  attendanceStats Float?   @default(100.0)
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatSession {
  id           String   @id @default(cuid())
  userId       String
  topicContext String?
  messages     Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExamPrep {
  id              String   @id @default(cuid())
  userId          String
  examName        String
  targetDate      DateTime
  importantTopics Json
  mockTests       Json
  revisionPlan    Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SyllabusTopic {
  id               String   @id @default(cuid())
  userId           String
  subjectName      String
  topicName        String
  difficulty       String
  subtopics        Json
  resources        Json?
  youtubeSearchUrl String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
